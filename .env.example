# Claude Code Discord Remote — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Discord Bot ───────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Right-click your server name → Copy Server ID (enable Developer Mode in Settings → Advanced)
DISCORD_GUILD_ID=your-guild-id-here

# ── Authorization ─────────────────────────────────────────
# Comma-separated Discord user IDs allowed to send commands.
# If empty, only the server owner can use the bot.
# Get your user ID: right-click your name in Discord → Copy User ID
# DISCORD_ALLOWED_USERS=123456789012345678

# ── Optional ──────────────────────────────────────────────
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Session timeout in hours
SESSION_TIMEOUT=24

# mlx-whisper path for voice transcription (future)
# MLX_WHISPER_PATH=/path/to/mlx_whisper
